{
  "name": "react-tailwindcss-debugger",
  "version": "1.0.2",
  "description": "A visual debugger for Tailwind CSS in React with real-time source syncing.",
  "author": "Ankit Chakraborty",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ankitchakraborty/react-tailwindcss-debugger"
  },
  "keywords": [
    "react",
    "tailwind",
    "debugger",
    "visual-editor",
    "dx",
    "styling"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "react-tailwindcss-debugger": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./babel": {
      "types": "./dist/babel.d.ts",
      "import": "./dist/babel.js",
      "require": "./dist/babel.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run clean && tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "framer-motion": ">=4.0.0",
    "lucide-react": ">=0.200.0",
    "@babel/core": "^7.23.0",
    "@babel/types": "^7.23.0"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
